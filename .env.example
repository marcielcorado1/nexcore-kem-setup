# ================================================================
# EvoNexus KEM Setup — Variáveis de Configuração
# ================================================================
# Cópia este arquivo para .env e ajuste os valores

# DOMÍNIO - obrigatório
DOMAIN=seu-dominio-aqui.com.br

# TIMEZONE - opcional (padrão: America/Sao_Paulo)
TZ=America/Sao_Paulo

# PORTAS - opcional (padrão: 8080 e 32352)
EVONEXUS_PORT=8080
TERMINAL_SERVER_PORT=32352

# ================================================================
# API KEYS E TOKENS — configure no Coolify UI após deploy
# ================================================================
# NÃO coloque dados sensíveis neste arquivo
# Use o painel do Coolify para configurar:
# - ANTHROPIC_API_KEY (Claude API)
# - OPENAI_API_KEY (se usar OpenAI)
# - GITHUB_TOKEN (para ativar GitHub integrations)
# - TELEGRAM_BOT_TOKEN (para bot Telegram)
# - STRIPE_API_KEY (para Stripe)
# - SUPABASE_URL (se usar Supabase externo)
# - Outras integrações conforme necessário

# Vantagem: dados sensíveis ficam no Coolify, não no git
